@page "/projects/minor/evaluation"
@using ntcc_admin_blazor.Components.Layout
@layout EmptyLayout

<!-- Full Screen Modal Style Workspace -->
<div class="d-flex flex-column h-screen w-100 bg-light">
    
    <!-- Workspace Header -->
    <MudPaper Elevation="2" Class="pa-2 px-6 d-flex justify-space-between align-center bg-white" Style="border-radius: 0; z-index: 10;">
        <div class="d-flex align-center">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/projects/minor/documents" Color="Color.Default" Class="mr-4" />
            <div>
                <MudText Typo="Typo.h6" Class="fw-bold">Evaluation Workspace</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Mid Term Draft - AI Malware Detection</MudText>
            </div>
        </div>
        <div class="d-flex align-center gap-4">
            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Outlined">Pending Grading</MudChip>
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.CheckCircle">Finalize Grade</MudButton>
        </div>
    </MudPaper>

    <!-- Split Screen Layout -->
    <div class="flex-grow-1 d-flex overflow-hidden">
        
        <!-- Document Pane (Left) -->
        <div class="w-50 h-100 d-flex flex-column border-r-1 border-solid mud-border-lines-default bg-dark">
            
            <div class="pa-2 bg-dark-light d-flex justify-space-between align-center">
                <MudText Typo="Typo.body2" Class="mud-text-secondary ml-2">proposal_v1.pdf</MudText>
                <div>
                     <MudIconButton Icon="@Icons.Material.Filled.ZoomIn" Color="Color.Surface" Size="Size.Small" />
                     <MudIconButton Icon="@Icons.Material.Filled.ZoomOut" Color="Color.Surface" Size="Size.Small" />
                </div>
            </div>

            <!-- PDF.js Canvas Area -->
            <div class="flex-grow-1 d-flex align-center justify-center">
                <div class="pa-10 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Surface" Size="Size.Large" Class="mb-4 opacity-50" />
                    <MudText Typo="Typo.h6" Color="Color.Surface" Class="opacity-50 fw-bold">PDF.js Document Render Engine</MudText>
                </div>
            </div>
        </div>

        <!-- Grading Rubric Pane (Right) -->
        <div class="w-50 h-100 d-flex flex-column bg-white overflow-y-auto pa-6">
            
            <MudText Typo="Typo.h5" Class="fw-bold mb-6 text-primary">Scoring Rubric - Mid Term</MudText>

            <!-- Dynamic Grading Form generated matching Criteria config -->
            <MudForm>
                <MudPaper Class="pa-4 mb-4 bg-light border-solid border-1 border-primary rounded-lg" Elevation="0">
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.subtitle1" Class="fw-bold">Analysis Depth</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Max: 10 Pts</MudText>
                    </div>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">Evaluate the depth of research and problem understanding.</MudText>
                    <div class="d-flex align-center gap-3">
                        <MudSlider T="int" Value="8" Max="10" Min="0" Color="Color.Primary" Class="flex-grow-1" />
                        <MudNumericField T="int" Value="8" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 70px" />
                    </div>
                </MudPaper>

                <MudPaper Class="pa-4 mb-4 bg-light border-solid border-1 mud-border-lines-default rounded-lg" Elevation="0">
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.subtitle1" Class="fw-bold">Presentation</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Max: 10 Pts</MudText>
                    </div>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">Clarity, formatting, and structural organization.</MudText>
                    <div class="d-flex align-center gap-3">
                        <MudSlider T="int" Value="0" Max="10" Min="0" Color="Color.Primary" Class="flex-grow-1" />
                        <MudNumericField T="int" Value="0" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 70px" />
                    </div>
                </MudPaper>

                <MudPaper Class="pa-4 mb-6 bg-light border-solid border-1 mud-border-lines-default rounded-lg" Elevation="0">
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.subtitle1" Class="fw-bold">Viva Voce</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Max: 10 Pts</MudText>
                    </div>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">Student's ability to answer technical cross-questioning.</MudText>
                    <div class="d-flex align-center gap-3">
                        <MudSlider T="int" Value="0" Max="10" Min="0" Color="Color.Primary" Class="flex-grow-1" />
                        <MudNumericField T="int" Value="0" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 70px" />
                    </div>
                </MudPaper>

                <MudTextField T="string" Label="Faculty Feedback (Visible to Student)" Variant="Variant.Outlined" Lines="4" Placeholder="Provide qualitative feedback on the submission here..." Class="mb-6" />

                <MudPaper Class="pa-4 bg-primary text-white rounded-lg d-flex justify-space-between align-center">
                    <MudText Typo="Typo.h6" Class="fw-bold">Calculated Score</MudText>
                    <MudText Typo="Typo.h4" Class="fw-black">8 / 30</MudText>
                </MudPaper>
            </MudForm>

        </div>
    </div>
</div>

<style>
    .h-screen { height: 100vh; }
    .bg-dark { background-color: #333333; }
    .bg-dark-light { background-color: #424242; }
    .fw-bold { font-weight: 700; }
    .fw-black { font-weight: 900; }
    .text-primary { color: #1976D2; }
    /* Hide scrolling on main app container for this specific page layout */
    body { overflow-y: hidden; } 
</style>
