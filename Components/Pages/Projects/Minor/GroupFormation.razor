@page "/projects/minor/groups"
@using ntcc_admin_blazor.Components.Layout
@layout MainLayout

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-16">
    <div class="d-flex justify-space-between align-center mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="fw-bold text-gradient">Team Formation</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Drag and drop students to assemble project groups</MudText>
        </div>
        <div>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Autorenew" Class="mr-2">Auto-Group</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save">Save Teams</MudButton>
        </div>
    </div>

    <!-- Quick Filters -->
    <MudPaper Class="pa-4 mb-6 rounded-lg d-flex gap-4 align-center bg-light" Elevation="1">
        <MudSelect T="string" Label="Select Batch" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Style="width: 200px;">
            <MudSelectItem Value="@("B.Tech CSE 2021-25")" />
            <MudSelectItem Value="@("BCA 2022-25")" />
        </MudSelect>
        <MudSelect T="string" Label="Department" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Style="width: 200px;">
            <MudSelectItem Value="@("Computer Science")" />
            <MudSelectItem Value="@("Information Tech")" />
        </MudSelect>
        <MudSpacer />
        <MudChip T="string" Color="Color.Info" Variant="Variant.Filled">124 Ungrouped</MudChip>
        <MudChip T="string" Color="Color.Success" Variant="Variant.Filled">8 Teams Formed</MudChip>
    </MudPaper>

    <MudGrid>
        <!-- Left: Unassigned Students Pool -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 rounded-xl h-100" Elevation="4">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Available Students</MudText>
                
                <MudTextField T="string" Placeholder="Search by Name/Enrollment..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" />
                
                <div class="pool-container pa-2 rounded" style="min-height: 500px; background: #f9fafc; border: 1px dashed #ccc;">
                    <Plk.Blazor.DragDrop.Dropzone Items="UnassignedStudents" TItem="StudentDto">
                        <div class="student-card pa-3 mb-2 rounded bg-white shadow-sm d-flex align-center">
                            <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-3">@context.Name.Substring(0,1)</MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle2" Class="fw-bold">@context.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.EnrollmentNo</MudText>
                            </div>
                        </div>
                    </Plk.Blazor.DragDrop.Dropzone>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Right: Group Workspaces -->
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-6 rounded-xl h-100" Elevation="4" Style="background: #fafafa;">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Project Groups</MudText>
                
                <MudGrid>
                    <!-- Iterate over pre-defined Team slots -->
                    @foreach (var team in Teams)
                    {
                        <MudItem xs="12" sm="6" lg="4">
                            <MudPaper Class="pa-4 rounded-lg shadow-sm border-t-4 border-primary h-100">
                                <div class="d-flex justify-space-between align-center mb-2">
                                    <MudText Typo="Typo.subtitle1" Class="fw-bold">@team.Name</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" />
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">Capacity: 3-4 Members</MudText>
                                
                                <div class="team-dropzone pa-2 rounded bg-light" style="min-height: 120px; border: 1px dashed #bbb;">
                                    <Plk.Blazor.DragDrop.Dropzone Items="team.Members" TItem="StudentDto">
                                        <div class="student-pill pa-2 mb-1 rounded bg-white border-solid border-1 mud-border-lines-default d-flex align-center justify-space-between">
                                            <MudText Typo="Typo.body2" Class="text-truncate">@context.Name</MudText>
                                            <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" /> <!-- Leader icon -->
                                        </div>
                                    </Plk.Blazor.DragDrop.Dropzone>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                    
                    <!-- Add New Team Button -->
                    <MudItem xs="12" sm="6" lg="4">
                        <MudPaper Class="pa-4 rounded-lg h-100 d-flex flex-column align-center justify-center cursor-pointer hover-pulse" Style="border: 2px dashed #1976D2; background: transparent;">
                            <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                            <MudText Typo="Typo.subtitle1" Color="Color.Primary" Class="fw-bold">Create New Group</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    public class StudentDto 
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Name { get; set; } = string.Empty;
        public string EnrollmentNo { get; set; } = string.Empty;
    }

    public class TeamDto
    {
        public string Name { get; set; } = string.Empty;
        public List<StudentDto> Members { get; set; } = new();
    }

    public List<StudentDto> UnassignedStudents = new()
    {
        new StudentDto { Name = "Aryan Sharma", EnrollmentNo = "A2305221001" },
        new StudentDto { Name = "Neha Gupta", EnrollmentNo = "A2305221002" },
        new StudentDto { Name = "Rahul Verma", EnrollmentNo = "A2305221003" },
        new StudentDto { Name = "Aditi Singh", EnrollmentNo = "A2305221004" }
    };

    public List<TeamDto> Teams = new()
    {
        new TeamDto { Name = "Group 1 (AI Detection)", Members = new() { new StudentDto { Name = "Existing Member", EnrollmentNo = "A2300000" } } },
        new TeamDto { Name = "Group 2 (Blockchain)", Members = new() }
    };
}

<style>
    .fw-bold { font-weight: 700; }
    .text-gradient {
        background: linear-gradient(90deg, #1976D2 0%, #0D47A1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .shadow-sm { box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
    .student-card { cursor: grab; transition: transform 0.2s; }
    .student-card:active { cursor: grabbing; transform: scale(0.98); }
    .student-pill { cursor: grab; font-size: 0.85rem; }
    .hover-pulse:hover {
        background: rgba(25, 118, 210, 0.05) !important;
        transform: scale(1.02);
        transition: all 0.2s;
    }
</style>
