@using MudBlazor

<MudPaper Class="pa-6 research-pub-widget h-100" Elevation="4">
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h6" Class="fw-bold text-white">Research & Pubs</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary opacity-80 text-white">Dean Metrics Tracker</MudText>
        </div>
        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Surface" Size="Size.Medium" />
    </div>

    <div class="glass-container mt-4 p-4 rounded-xl">
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.body2" Class="fw-bold text-white text-uppercase">IEEE Submissions</MudText>
            <MudText Typo="Typo.h6" Class="fw-black text-white">0</MudText>
        </div>
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.body2" Class="fw-bold text-white text-uppercase">Springer Journals</MudText>
            <MudText Typo="Typo.h6" Class="fw-black text-white">0</MudText>
        </div>
        <div class="d-flex justify-space-between align-center">
            <MudText Typo="Typo.body2" Class="fw-bold text-white text-uppercase">Scopus Indexed</MudText>
            <MudText Typo="Typo.h6" Class="fw-black text-white text-decoration-underline">0</MudText>
        </div>
    </div>

    <MudButton Variant="Variant.Outlined" Class="mt-6 w-100 fw-bold border-white text-white custom-hover-btn">Download Bibliography</MudButton>
</MudPaper>

<style>
    .research-pub-widget {
        border-radius: 16px;
        background: linear-gradient(135deg, #FF6B6B 0%, #C0392B 100%);
        color: white;
    }
    .glass-container {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 16px;
    }
    .fw-black { font-weight: 900; }
    .fw-bold { font-weight: 700; }
    .custom-hover-btn:hover {
        background: rgba(255, 255, 255, 0.1) !important;
    }
</style>
