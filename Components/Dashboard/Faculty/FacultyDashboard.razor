@page "/faculty/dashboard"
@using ntcc_admin_blazor.Application.DTOs
@using ntcc_admin_blazor.Application.Services
@using ntcc_admin_blazor.Domain.Entities
@using ntcc_admin_blazor.Domain.Enums
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@inject IDashboardService DashboardService
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = "faculty,admin,master")]
@rendermode InteractiveServer

<PageTitle>Faculty Dashboard - NTCC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <!-- Header Section -->
    <div class="d-flex justify-space-between align-end mb-8">
        <div class="animate-fade-in">
            <MudText Typo="Typo.h3" Class="fw-black premium-gradient-text">Welcome back, @userName</MudText>
            <MudText Typo="Typo.h6" Class="mud-text-secondary">@userRole.ToUpper() PORTAL — NTCC Academic Lifecycle Control</MudText>
        </div>
        <div class="d-flex gap-3">
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary" Icon="@Icons.Material.Filled.Event" Class="px-4 py-2 rounded-lg">Semester 5</MudChip>
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Secondary" Icon="@Icons.Material.Filled.BatchPrediction" Class="px-4 py-2 rounded-lg">Batch 2023</MudChip>
        </div>
    </div>

    @if (isLoading)
    {
        <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Class="my-4" />
    }
    else
    {
        <ntcc_admin_blazor.Components.Dashboard.WidgetContainer Widgets="@widgets" />
    }

</MudContainer>

@code {
    bool isLoading = true;
    string userName = "";
    string userRole = "";
    List<WidgetDto> widgets = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            userName = authState.User.Identity?.Name ?? "Faculty";
            userRole = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "faculty";
            
            // Faculty defaults loaded explicitly
            widgets = new List<WidgetDto>
            {
                new WidgetDto { ComponentKey = "attendance_tracker", Type = ComponentType.Academic, ConfigJson = "{}", Order = 1 },
                new WidgetDto { ComponentKey = "deadline_timer", Type = ComponentType.Metric, ConfigJson = "{}", Order = 2 },
            };

            // DB extensions added implicitly
            var extraWidgets = await DashboardService.GetGlobalWidgetsAsync("faculty");
            widgets.AddRange(extraWidgets);
        }
        catch 
        { 
            userName = "Faculty"; 
            userRole = "faculty";
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
    .premium-gradient-text {
        background: linear-gradient(135deg, #1976D2 0%, #9C27B0 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .fw-black { font-weight: 900; }
    
    .animate-fade-in {
        animation: fadeIn 0.8s ease-out;
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
