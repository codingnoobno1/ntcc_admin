@using ntcc_admin_blazor.Components.Shared
<MudNavMenu>
    <MudNavLink href="faculty/dashboard" Icon="@Icons.Material.Filled.Dashboard" Class="nav-item-premium">Overview</MudNavLink>
    
    <MudNavGroup Title="Academics" Icon="@Icons.Material.Filled.School" Expanded="true">
        <PermissionView Permission="manage_students">
            <MudNavLink href="students" Icon="@Icons.Material.Filled.People">Student Directory</MudNavLink>
        </PermissionView>
    </MudNavGroup>
    
    <MudNavGroup Title="Projects" Icon="@Icons.Material.Filled.AccountTree" Expanded="true">
        <PermissionView Permission="manage_projects">
            <MudNavLink href="faculty/proposals" Icon="@Icons.Material.Filled.FactCheck">Proposal Vetting</MudNavLink>
            <MudNavLink href="projects/minor" Icon="@Icons.Material.Filled.FolderSpecial">Minor Projects</MudNavLink>
        </PermissionView>
    </MudNavGroup>
    
    <MudNavGroup Title="Internships" Icon="@Icons.Material.Filled.BusinessCenter" Expanded="true">
        <PermissionView Permission="manage_internships">
            <MudNavLink href="internships" Icon="@Icons.Material.Filled.TrackChanges">Internship Monitor</MudNavLink>
            <MudNavLink href="admin/companies" Icon="@Icons.Material.Filled.Business">Companies</MudNavLink>
        </PermissionView>
    </MudNavGroup>
    
    <MudNavGroup Title="Evaluations" Icon="@Icons.Material.Filled.FactCheck" Expanded="true">
        <PermissionView Permission="evaluate_submission">
            <MudNavLink href="evaluation/workspace" Icon="@Icons.Material.Filled.Grading">Workspace</MudNavLink>
            <MudNavLink href="evaluation-panel" Icon="@Icons.Material.Filled.ListAlt">Evaluation Panel</MudNavLink>
        </PermissionView>
    </MudNavGroup>
</MudNavMenu>

<style>
    .mud-nav-link.active {
        background-color: rgba(25, 118, 210, 0.05) !important;
        color: #1976D2 !important;
        font-weight: 600;
        border-right: 3px solid #1976D2;
    }
    .mud-nav-link:hover {
        background-color: rgba(25, 118, 210, 0.03) !important;
    }
</style>
