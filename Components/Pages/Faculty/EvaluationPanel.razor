@page "/faculty/evaluation-panel/{StudentId}/{StageTypeId}"
@using ntcc_admin_blazor.Domain.Entities
@using ntcc_admin_blazor.Application.DTOs
@using ntcc_admin_blazor.Application.Services
@inject IWorkflowService WorkflowService
@inject SupabaseService Supabase
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Evaluation Panel - NTCC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <div class="d-flex align-center mb-6">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" href="/faculty/student-progress" Class="mr-4" />
        <div>
            <MudText Typo="Typo.h4" Class="fw-bold">Student <span class="text-primary">Evaluation</span></MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Viva Voce & Artefact Verification</MudText>
        </div>
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudGrid>
            @* Left Side: Student Info & Artefacts *@
            <MudItem xs="12" md="7">
                <MudPaper Class="pa-6 rounded-xl mb-6 shadow-sm" Elevation="0">
                    <div class="d-flex align-start mb-4">
                        <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-4 mt-1">@_studentName[0]</MudAvatar>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-space-between align-start">
                                <div>
                                    <MudText Typo="Typo.h5" Class="fw-bold">@_studentName</MudText>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Enrolment: @_studentId</MudText>
                                </div>
                                <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Icon="@Icons.Material.Filled.School">B.Tech CSE - VII</MudChip>
                            </div>
                            <MudDivider Class="my-4" />
                            <MudGrid>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Project Title</MudText>
                                    <MudText Typo="Typo.body1" Class="fw-bold">Automated Academic Workflow Discovery using LLMs</MudText>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Supervisor</MudText>
                                    <MudText Typo="Typo.body2">Prof. Amit Kumar</MudText>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Stage Type</MudText>
                                    <MudText Typo="Typo.body2">Minor Project</MudText>
                                </MudItem>
                            </MudGrid>
                        </div>
                    </div>
                </MudPaper>

                <MudTabs Elevation="4" Rounded="true" Color="Color.Primary" ContentClass="pa-6 rounded-b-xl" Class="evaluation-tabs mb-6">
                    <MudTabPanel Text="Meeting History" Icon="@Icons.Material.Filled.History">
                        <div class="d-flex justify-space-between mb-4">
                            <MudText Typo="Typo.subtitle1" Class="fw-bold">Supervisor Interactions</MudText>
                            <MudChip T="string" Color="@(GetMeetingColor())" Size="Size.Small">@_meetings.Count / @_dashboard?.RequiredMeetings Logs</MudChip>
                        </div>
                        <MudTimeline TimelinePosition="TimelinePosition.Start">
                            @foreach (var meeting in _meetings)
                            {
                                <MudTimelineItem Color="Color.Info" Size="Size.Small">
                                    <ItemContent>
                                        <div class="d-flex justify-space-between">
                                            <MudText Typo="Typo.subtitle2" Class="fw-bold">@(((DateTime)meeting.MeetingDate).ToString("MMM dd, yyyy"))</MudText>
                                            <MudRating ReadOnly="true" SelectedValue="@meeting.ProgressScore" MaxValue="5" Size="Size.Small" />
                                        </div>
                                        <MudText Typo="Typo.body2" Class="mt-1">@meeting.Summary</MudText>
                                        @if (!string.IsNullOrEmpty(meeting.ReportUrl))
                                        {
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Attachment" Size="Size.Small" Class="mt-2" Href="@meeting.ReportUrl" Target="_blank">Download log</MudButton>
                                        }
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                    </MudTabPanel>

                    <MudTabPanel Text="Submitted Artefacts" Icon="@Icons.Material.Filled.FolderOpen">
                        <MudText Typo="Typo.subtitle1" Class="fw-bold mb-4">Verification Checkpoint</MudText>
                        <MudTable Items="_dashboard?.Steps.Where(s => s.RequiresSubmission)" Hover="true" Elevation="0" Class="mud-table-transparent">
                            <HeaderContent>
                                <MudTh>Step Name</MudTh>
                                <MudTh>Submission</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Name</MudTd>
                                <MudTd>@(context.SubmittedAt?.ToString("g"))</MudTd>
                                <MudTd>
                                    <MudChip T="string" Color="@(context.Status == Domain.Enums.StepStatus.Approved ? Color.Success : Color.Warning)" Size="Size.Small">@context.Status</MudChip>
                                </MudTd>
                                <MudTd DataLabel="Actions">
                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Primary" Size="Size.Small" />
                                    <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudTabPanel>
                </MudTabs>
            </MudItem>

            @* Right Side: Evaluation Rubric *@
            <MudItem xs="12" md="5">
                <MudPaper Class="pa-6 rounded-xl sticky-rubric shadow-lg" Elevation="4">
                    <div class="d-flex justify-space-between align-center mb-6">
                        <MudText Typo="Typo.h6" Class="fw-bold">Assessment Rubric</MudText>
                        <MudChip T="string" Color="Color.Secondary" Size="Size.Small">Midterm</MudChip>
                    </div>
                    
                    @if (_rubric == null)
                    {
                        <MudAlert Severity="Severity.Info">No rubric defined for this stage type.</MudAlert>
                    }
                    else
                    {
                        <MudStack Spacing="6">
                            @foreach (var comp in _rubric.Components)
                            {
                                <div>
                                    <div class="d-flex justify-space-between mb-1">
                                        <MudText Typo="Typo.body1" Class="fw-bold">@comp.ComponentName</MudText>
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Max @comp.MaxMarks</MudText>
                                    </div>
                                    <MudNumericField T="int" Value="@_evaluationStatus.AggregateScore" Label="Current Total" ReadOnly="true" Margin="Margin.Dense" Variant="Variant.Outlined" Color="Color.Primary" Class="fw-bold" />
                                    <MudTextField @bind-Value="comp.Remarks" Label="Coordinator Remarks" Variant="Variant.Text" Placeholder="Strengths/Weaknesses..." Class="mt-1" />
                                </div>
                            }

                            <MudDivider Class="my-4" />
                            <div class="pa-4 rounded-lg bg-light d-flex justify-space-between align-center border border-dashed border-primary">
                                <MudText Typo="Typo.h6" Class="fw-bold text-primary">Consolidated Score</MudText>
                                <MudText Typo="Typo.h3" Color="Color.Primary" Class="fw-bold">@_rubric.Components.Sum(c => c.MarksObtained) / @_rubric.TotalMarks</MudText>
                            </div>

                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" Class="mt-4 py-4 rounded-xl" OnClick="SubmitEvaluation">Submit Viva Assessment</MudButton>
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter] public string StudentId { get; set; } = string.Empty;
    [Parameter] public string StageTypeId { get; set; } = string.Empty;

    private string _studentName = "Loading...";
    private string _studentId = "";
    private bool _isLoading = true;
    
    private StageDashboardDto? _dashboard;
    private List<SupervisorMeetingDto> _meetings = new();
    private EvaluationRubricDto? _rubric;
    private EvaluationStatus _evaluationStatus = new();

    class EvaluationStatus { public int AggregateScore { get; set; } }

    protected override async Task OnInitializedAsync()
    {
        _studentId = StudentId;
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            // In a real app, we'd get student details from profiles table
            _studentName = "Rahul Sharma"; 
            
            // Assuming we determine program/sem from student state, hardcoding for demo
            _dashboard = await WorkflowService.GetStageDashboardAsync(StudentId, "prog-1", 6);
            _meetings = await WorkflowService.GetStudentMeetingsAsync(StudentId);
            _rubric = await WorkflowService.GetEvaluationRubricAsync(StageTypeId, "midterm");
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading evaluation data: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Color GetMeetingColor()
    {
        if (_dashboard == null) return Color.Default;
        return _meetings.Count >= _dashboard.RequiredMeetings ? Color.Success : Color.Warning;
    }

    private async Task SubmitEvaluation()
    {
        try
        {
            if (_rubric == null) return;
            
            // Verify if components sum up correctly or check for missing marks
            // For now, just submit
            await WorkflowService.SubmitEvaluationAsync(StudentId, _rubric.Id, _rubric.Components, "faculty-1");
            Snackbar.Add("Evaluation submitted successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error submitting evaluation: " + ex.Message, Severity.Error);
        }
    }
}

<style>
    .fw-bold { font-weight: 700; }
    .sticky-rubric {
        position: sticky;
        top: 24px;
    }
    .rounded-xl { border-radius: 16px !important; }
</style>
