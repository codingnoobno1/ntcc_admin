@page "/projects/minor/stages"
@using ntcc_admin_blazor.Components.Layout
@layout MainLayout

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-16">
    <div class="d-flex justify-space-between align-center mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="fw-bold text-gradient">Stage Engine</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Configure Minor Project workflows and deadlines</MudText>
        </div>
        <div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="fw-bold mr-2">New Stage</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh">Reload</MudButton>
        </div>
    </div>

    <MudGrid>
        <!-- Top Half: Timeline View -->
        <MudItem xs="12">
            <MudPaper Class="pa-6 rounded-xl" Elevation="4">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Workflow Visualization</MudText>
                
                <!-- Placeholder for Vis.js Timeline integration -->
                <div class="timeline-container border-solid border-2 mud-border-lines-default rounded-lg pa-4 d-flex align-center justify-center bg-light">
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                    <MudText Typo="Typo.h6" Color="Color.Primary" Class="fw-bold">Interactive Timeline (Vis.js)</MudText>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Bottom Left: Stage Editor -->
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-6 rounded-xl h-100" Elevation="4">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Stage Configuration</MudText>
                
                <MudForm>
                    <MudTextField T="string" Label="Stage Title" Value="@("Proposal Submission")" Variant="Variant.Outlined" Class="mb-4" />
                    
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker Label="Start Date" Date="@(DateTime.Today)" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker Label="End Date" Date="@(DateTime.Today.AddDays(14))" Variant="Variant.Outlined" />
                        </MudItem>
                    </MudGrid>

                    <MudSelect T="string" Label="Required Document" Variant="Variant.Outlined" Class="mt-4" Value="@("Proposal Document (PDF)")">
                        <MudSelectItem Value="@("Proposal Document (PDF)")" />
                        <MudSelectItem Value="@("Draft Report (PDF)")" />
                        <MudSelectItem Value="@("Final Report (PDF)")" />
                        <MudSelectItem Value="@("Presentation (.PPTX)")" />
                    </MudSelect>

                    <div class="d-flex justify-end mt-6">
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" Class="mr-2">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary">Save Configuration</MudButton>
                    </div>
                </MudForm>
            </MudPaper>
        </MudItem>

        <!-- Bottom Right: Current Workflows List -->
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-6 rounded-xl h-100" Elevation="4">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Current Stages</MudText>
                
                <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelinePosition="TimelinePosition.Start">
                    <MudTimelineItem Color="Color.Success" Size="Size.Small">
                        <ItemContent>
                            <MudText Typo="Typo.subtitle2" Class="fw-bold">1. Title Approval</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Completed</MudText>
                        </ItemContent>
                    </MudTimelineItem>
                    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                        <ItemContent>
                            <MudText Typo="Typo.subtitle2" Class="fw-bold">2. Proposal Submission</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Active (Due in 5 Days)</MudText>
                        </ItemContent>
                    </MudTimelineItem>
                    <MudTimelineItem Color="Color.Default" Size="Size.Small">
                        <ItemContent>
                            <MudText Typo="Typo.subtitle2" Class="mud-text-disabled">3. Mid Term Evaluation</MudText>
                        </ItemContent>
                    </MudTimelineItem>
                </MudTimeline>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .fw-bold { font-weight: 700; }
    .text-gradient {
        background: linear-gradient(90deg, #1976D2 0%, #0D47A1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .timeline-container {
        height: 250px;
        background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(249,250,252,1) 100%);
    }
</style>
