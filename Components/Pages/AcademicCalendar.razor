@page "/admin/academic-calendar"
@using ntcc_admin_blazor.Domain.Entities
@inject SupabaseService Supabase
@inject IAcademicCalendarService CalendarService
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Academic Calendar - NTCC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="fw-bold mb-6">Academic <span class="text-primary">Calendar</span></MudText>

    <MudGrid>
        <MudItem xs="12">
            <MudPaper Class="pa-6 glass-card">
                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6">Academic Configuration & Cycle</MudText>
                    <MudButton StartIcon="@Icons.Material.Filled.Settings" Color="Color.Primary" OnClick="() => _configOpen = true">Adjust Offsets</MudButton>
                </div>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                    Current settings: Odd Sem starts <b>@_config.OddSemStartMonth/@_config.OddSemStartDay</b>, Even Sem starts <b>@_config.EvenSemStartMonth/@_config.EvenSemStartDay</b>.
                </MudAlert>
                <MudSimpleTable Style="overflow-x: auto;">
                    <thead>
                        <tr>
                            <th>Period</th>
                            <th>Range (Standard)</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Odd Semesters</td>
                            <td>@_config.OddSemStartMonth/@_config.OddSemStartDay - @_config.OddSemEndMonth/@_config.OddSemEndDay</td>
                            <td><MudChip T="string" Size="Size.Small" Color="Color.Primary">Academic</MudChip></td>
                        </tr>
                        <tr>
                            <td>Even Semesters</td>
                            <td>@_config.EvenSemStartMonth/@_config.EvenSemStartDay - @_config.EvenSemEndMonth/@_config.EvenSemEndDay</td>
                            <td><MudChip T="string" Size="Size.Small" Color="Color.Secondary">Academic</MudChip></td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>

        <MudDialog @bind-Visible="_configOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
            <TitleContent>Academic Cycle Configuration</TitleContent>
            <DialogContent>
                <MudStack Spacing="3">
                    <MudText Typo="Typo.caption">Gaps between these ranges will automatically appear as Breaks/Internships.</MudText>
                    <MudGrid>
                        <MudItem xs="6">
                            <MudText Typo="Typo.subtitle2">Odd Semester</MudText>
                            <div class="d-flex gap-2">
                                <MudNumericField @bind-Value="_config.OddSemStartMonth" Label="Start Month" Min="1" Max="12" />
                                <MudNumericField @bind-Value="_config.OddSemStartDay" Label="Day" Min="1" Max="31" />
                            </div>
                            <div class="d-flex gap-2">
                                <MudNumericField @bind-Value="_config.OddSemEndMonth" Label="End Month" Min="1" Max="12" />
                                <MudNumericField @bind-Value="_config.OddSemEndDay" Label="Day" Min="1" Max="31" />
                            </div>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.subtitle2">Even Semester</MudText>
                            <div class="d-flex gap-2">
                                <MudNumericField @bind-Value="_config.EvenSemStartMonth" Label="Start Month" Min="1" Max="12" />
                                <MudNumericField @bind-Value="_config.EvenSemStartDay" Label="Day" Min="1" Max="31" />
                            </div>
                            <div class="d-flex gap-2">
                                <MudNumericField @bind-Value="_config.EvenSemEndMonth" Label="End Month" Min="1" Max="12" />
                                <MudNumericField @bind-Value="_config.EvenSemEndDay" Label="Day" Min="1" Max="31" />
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="() => _configOpen = false">Close</MudButton>
                <MudButton Color="Color.Primary" OnClick="ApplyConfig">Apply Globally</MudButton>
            </DialogActions>
        </MudDialog>

        <MudItem xs="12">
            <MudText Typo="Typo.h6" Class="mt-6 mb-4">Batch Timelines</MudText>
            @if (_isLoading)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }
            else
            {
                <MudExpansionPanels MultiExpansion="true">
                    @foreach (var batch in _batches)
                    {
                        <MudExpansionPanel Text="@($"Batch {batch.Name} ({batch.StartYear} - {batch.EndYear})")">
                            <TitleContent>
                                @{
                                    int totalYears = batch.EndYear - batch.StartYear;
                                    int currentSem = CalendarService.CalculateCurrentSemester(batch.StartYear, totalYears, _config);
                                }
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Groups" Class="mr-3" />
                                    <MudText>Batch <b>@batch.Name</b></MudText>
                                    <MudSpacer />
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">Sem @currentSem</MudChip>
                                </div>
                            </TitleContent>
                            <ChildContent>
                                <MudTimeline TimelinePosition="TimelinePosition.Start">
                                    @{
                                        int totalYearsLocal = batch.EndYear - batch.StartYear;
                                        int currentSemLocal = CalendarService.CalculateCurrentSemester(batch.StartYear, totalYearsLocal, _config);
                                        var fullTimeline = CalendarService.GetFullTimeline(batch.StartYear, totalYearsLocal, _config);
                                        var now = DateTime.Now;
                                    }
                                    @foreach (var item in fullTimeline)
                                    {
                                        bool isActive = now >= item.Start && now <= item.End;
                                        bool isPast = now > item.End;

                                        <MudTimelineItem Color="@(isActive ? Color.Primary : isPast ? Color.Success : Color.Default)"
                                                        Variant="@(item.Type == "Break" ? Variant.Outlined : Variant.Filled)">
                                            <ItemContent>
                                                <MudPaper Elevation="0" Class="@($"pa-3 rounded-lg {(item.Type == "Break" ? "mud-alert-text-warning" : "mud-background-gray")}")">
                                                    <div class="d-flex justify-space-between align-center">
                                                        <MudText Typo="Typo.subtitle2" Class="fw-bold">
                                                            @(item.Type == "Break" ? "Academic Break / Internship" : $"Semester {item.SemNum}")
                                                        </MudText>
                                                        @if (isActive)
                                                        {
                                                            <MudChip T="string" Color="Color.Primary" Size="Size.Small">CURRENT</MudChip>
                                                        }
                                                    </div>
                                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@item.Start.ToString("MMMM dd, yyyy") - @item.End.ToString("MMMM dd, yyyy")</MudText>
                                                </MudPaper>
                                            </ItemContent>
                                        </MudTimelineItem>
                                    }
                                </MudTimeline>
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<BatchEntity> _batches = new();
    private bool _isLoading = true;
    private bool _configOpen = false;
    private AcademicConfig _config = new AcademicConfig();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _batches = await Supabase.GetAll<BatchEntity>();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading batches", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyConfig()
    {
        _configOpen = false;
        Snackbar.Add("Calendar configuration updated!", Severity.Success);
        StateHasChanged();
    }
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.7) !important;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
        border-radius: 16px !important;
    }
    .fw-bold { font-weight: 700; }
</style>
