@page "/stages"
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Academic Stages - NTCC Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-2 fw-bold">Academic <span class="text-primary">Lifecycle Management</span></MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">Configure and track the NTCC progression for the current session.</MudText>

    <MudTimeline TimelinePosition="TimelinePosition.Left">
        @foreach (var stage in _academicStages)
        {
            <MudTimelineItem Color="@(stage.IsActive ? Color.Primary : Color.Default)" Size="Size.Small" Elevation="4">
                <ItemContent>
                    <MudPaper Class="pa-6 mb-4" Elevation="1">
                        <div class="d-flex justify-space-between align-center mb-2">
                            <MudText Typo="Typo.h6" Class="fw-bold">@stage.Name</MudText>
                            <MudChip T="string" Color="@(stage.IsActive ? Color.Primary : Color.Default)" Variant="Variant.Text" Size="Size.Small">
                                @(stage.IsActive ? "ACTIVE STAGE" : "UPCOMING / INACTIVE")
                            </MudChip>
                        </div>
                        <MudText Typo="Typo.body2" Class="mb-4">@stage.Description</MudText>
                        
                        <MudGrid>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">SEMESTER</MudText>
                                <MudText Typo="Typo.body2" Class="fw-bold">@stage.Semester</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">HOST FACULTY</MudText>
                                <MudText Typo="Typo.body2" Class="fw-bold">@stage.Host</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">SUBMISSIONS</MudText>
                                <MudText Typo="Typo.body2" Class="fw-bold">@stage.SubmissionCount / @stage.TotalStudents</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3" Class="text-right">
                                <div class="d-flex align-center justify-end">
                                    <MudSwitch T="bool" @bind-Value="stage.IsActive" Color="Color.Primary" Label="Open Submission" UnCheckedColor="Color.Default" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" Class="ml-2" />
                                </div>
                            </MudItem>
                        </MudGrid>

                        @if (stage.IsActive)
                        {
                            <MudAlert Severity="Severity.Info" Class="mt-4" Dense="true" Elevation="0">
                                This stage is currently accepting student uploads. Evaluation queue is being populated.
                            </MudAlert>
                        }
                    </MudPaper>
                </ItemContent>
            </MudTimelineItem>
        }
    </MudTimeline>
</MudContainer>

