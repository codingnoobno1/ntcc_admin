@page "/admin/academic-calendar"
@using ntcc_admin_blazor.Domain.Entities
@inject SupabaseService Supabase
@inject IAcademicCalendarService CalendarService
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Academic Calendar - NTCC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="fw-bold mb-6">Academic <span class="text-primary">Calendar</span></MudText>

    <MudGrid>
        <MudItem xs="12">
            <MudPaper Class="pa-6 glass-card">
                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6">Academic Configuration & Cycle</MudText>
                    <MudButton StartIcon="@Icons.Material.Filled.Settings" Color="Color.Primary" OnClick="() => _configOpen = true">Adjust Offsets</MudButton>
                </div>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                    Current settings: Odd Sem starts <b>@_config.OddSemStartMonth/@_config.OddSemStartDay</b>, Even Sem starts <b>@_config.EvenSemStartMonth/@_config.EvenSemStartDay</b>.
                </MudAlert>
                <MudSimpleTable Style="overflow-x: auto;">
                    <thead>
                        <tr>
                            <th>Period</th>
                            <th>Start (Standard)</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Odd Semesters (1, 3, 5, 7)</td>
                            <td>@_config.OddSemStartMonth/@_config.OddSemStartDay</td>
                            <td><MudChip T="string" Size="Size.Small" Color="Color.Primary">Academic</MudChip></td>
                        </tr>
                        <tr>
                            <td>Even Semesters (2, 4, 6, 8)</td>
                            <td>@_config.EvenSemStartMonth/@_config.EvenSemStartDay</td>
                            <td><MudChip T="string" Size="Size.Small" Color="Color.Secondary">Academic</MudChip></td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>

        <MudDialog @bind-Visible="_configOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
            <TitleContent>Academic Date Configuration</TitleContent>
            <DialogContent>
                <MudStack Spacing="3">
                    <MudText Typo="Typo.caption">Adjust the start of the academic cycle. Changes apply globally to calculations.</MudText>
                    <div class="d-flex gap-4">
                        <MudNumericField @bind-Value="_config.OddSemStartMonth" Label="Odd Sem Start Month" Min="1" Max="12" />
                        <MudNumericField @bind-Value="_config.OddSemStartDay" Label="Day" Min="1" Max="31" />
                    </div>
                    <div class="d-flex gap-4">
                        <MudNumericField @bind-Value="_config.EvenSemStartMonth" Label="Even Sem Start Month" Min="1" Max="12" />
                        <MudNumericField @bind-Value="_config.EvenSemStartDay" Label="Day" Min="1" Max="31" />
                    </div>
                </MudStack>
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="() => _configOpen = false">Close</MudButton>
                <MudButton Color="Color.Primary" OnClick="ApplyConfig">Apply Globally</MudButton>
            </DialogActions>
        </MudDialog>

        <MudItem xs="12">
            <MudText Typo="Typo.h6" Class="mt-6 mb-4">Batch Timelines</MudText>
            @if (_isLoading)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }
            else
            {
                <MudExpansionPanels MultiExpansion="true">
                    @foreach (var batch in _batches)
                    {
                        <MudExpansionPanel Text="@($"Batch {batch.Name} ({batch.StartYear} - {batch.EndYear})")">
                            <TitleContent>
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Groups" Class="mr-3" />
                                    <MudText>Batch <b>@batch.Name</b></MudText>
                                    <MudSpacer />
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">Sem @CalendarService.CalculateCurrentSemester(batch.StartYear, 4)</MudChip>
                                </div>
                            </TitleContent>
                            <ChildContent>
                                <MudTimeline TimelinePosition="TimelinePosition.Start">
                                    @{
                                        int totalYears = batch.EndYear - batch.StartYear;
                                        int totalSems = totalYears * 2;
                                    }
                                    @for (int i = 1; i <= totalSems; i++)
                                    {
                                        var range = CalendarService.GetSemesterDateRange(batch.StartYear, i);
                                        var currentSem = CalendarService.CalculateCurrentSemester(batch.StartYear, totalYears);
                                        <MudTimelineItem Color="@(i == currentSem ? Color.Primary : i < currentSem ? Color.Success : Color.Default)">
                                            <ItemContent>
                                                <MudPaper Elevation="0" Class="pa-3 mud-background-gray rounded-lg">
                                                    <MudText Typo="Typo.subtitle2" Class="fw-bold">Semester @i</MudText>
                                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@range.Start.ToString("MMMM dd, yyyy") - @range.End.ToString("MMMM dd, yyyy")</MudText>
                                                </MudPaper>
                                            </ItemContent>
                                        </MudTimelineItem>
                                    }
                                </MudTimeline>
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<BatchEntity> _batches = new();
    private bool _isLoading = true;
    private bool _configOpen = false;
    private AcademicConfig _config = new AcademicConfig();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _batches = await Supabase.GetAll<BatchEntity>();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading batches", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyConfig()
    {
        _configOpen = false;
        Snackbar.Add("Calendar configuration updated!", Severity.Success);
        StateHasChanged();
    }
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.7) !important;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
        border-radius: 16px !important;
    }
    .fw-bold { font-weight: 700; }
</style>
