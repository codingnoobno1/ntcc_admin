@page "/students"
@using ntcc_admin_blazor.Domain.Entities
@using ntcc_admin_blazor.Application.Services
@using ntcc_admin_blazor.Models
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@inject IStudentAppService StudentService
@inject IStageAppService StageService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject SupabaseService Supabase
@inject IAcademicCalendarService CalendarService
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Student Directory - NTCC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h5" Class="fw-bold">Student <span class="text-secondary">Directory</span></MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Manage and track student academic lifecycle</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="OpenAddDialog" Class="rounded-pill">
            Register Student
        </MudButton>
    </div>

    <!-- Stats Row -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="pa-4 glass-card d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Large" Class="mr-4" />
                <div>
                    <MudText Typo="Typo.h4" Class="fw-bold">@students.Count</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Total Students</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="pa-4 glass-card d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mr-4" />
                <div>
                    <MudText Typo="Typo.h4" Class="fw-bold">@students.Count(s => s.Status == "active")</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Active Students</MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Filters -->
    <MudPaper Elevation="0" Class="pa-4 mb-4 glass-card">
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="searchString" Placeholder="Search by Name or Roll No" Adornment="Adornment.Start" 
                               AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="Guid?" 
                           Label="Batch" 
                           Value="filterBatch" 
                           AnchorOrigin="Origin.BottomCenter" 
                           Variant="Variant.Outlined" 
                           Dense="true" 
                           ValueChanged="BatchFilterChanged">
                    <MudSelectItem Value="@((Guid?)null)">All Batches</MudSelectItem>
                    @foreach (var b in batches)
                    {
                        <MudSelectItem Value="@((Guid?)Guid.Parse(b.Id))">@b.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string" 
                           Label="Status" 
                           @bind-Value="filterStatus" 
                           AnchorOrigin="Origin.BottomCenter" 
                           Variant="Variant.Outlined" 
                           Dense="true">
                    <MudSelectItem Value="@((string?)null)">All Statuses</MudSelectItem>
                    <MudSelectItem Value="@("active")">Active</MudSelectItem>
                    <MudSelectItem Value="@("passed_out")">Passed Out</MudSelectItem>
                    <MudSelectItem Value="@("detained")">Detained</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Student Table -->
    <MudPaper Elevation="0" Class="glass-card">
        @if (isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudTable Items="@filteredStudents" Dense="true" Hover="true" Striped="true" Bordered="false" Elevation="0"
                      Filter="SearchFilter" Class="mud-table-transparent">
                <HeaderContent>
                    <MudTh>Roll No</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Batch</MudTh>
                    <MudTh>Semester</MudTh>
                    <MudTh>Active Module</MudTh>
                    <MudTh>GDrive</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Lifecycle</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        var batch = batches.FirstOrDefault(b => b.Id == context.BatchId?.ToString());
                        int admissionYear = batch?.StartYear ?? context.EnrollmentYear;
                        int totalYears = (batch != null && batch.EndYear > batch.StartYear) ? (batch.EndYear - batch.StartYear) : 4;
                        int currentSem = CalendarService.CalculateCurrentSemester(admissionYear, totalYears);
                        string programId = batch?.ProgramId ?? "";
                    }
                    <MudTd DataLabel="Roll No">
                        <MudText Typo="Typo.body2" Class="fw-bold">
                            @(string.IsNullOrEmpty(context.RollNumber) ? context.EnrollmentNumber : context.RollNumber)
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Name">@context.FullName</MudTd>
                    <MudTd DataLabel="Email">@context.Email</MudTd>
                    <MudTd DataLabel="Batch">@GetBatchName(context.BatchId)</MudTd>
                    <MudTd DataLabel="Semester">Sem @currentSem</MudTd>
                    <MudTd DataLabel="Active Module">
                        @{
                            var activeRule = GetActiveRule(programId, currentSem);
                            if (activeRule != null)
                            {
                                var stageName = stages.FirstOrDefault(s => s.Id == activeRule.StageTypeId)?.Name ?? "Assigned";
                                <MudChip T="string" Color="Color.Secondary" Size="Size.Small" Variant="Variant.Filled">@stageName</MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-disabled">None</MudText>
                            }
                        }
                    </MudTd>
                    <MudTd DataLabel="GDrive">
                        @if (!string.IsNullOrEmpty(GetGDriveLink(context.Id)))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.CloudQueue" Color="Color.Info" Size="Size.Small" 
                                           Href="@GetGDriveLink(context.Id)" Target="_blank" />
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-disabled">No Link</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Text">@context.Status</MudChip>
                    </MudTd>
                    <MudTd>
                        <MudTooltip Text="View Progress">
                            <MudIconButton Icon="@Icons.Material.Filled.Timeline" Size="Size.Small" Color="Color.Info" OnClick="() => ViewProgress(context)" />
                        </MudTooltip>
                    </MudTd>
                    <MudTd>
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="() => EditStudent(context)">Edit</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.History" OnClick="() => ViewLogs(context)">History</MudMenuItem>
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                </PagerContent>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

<!-- Add/Edit Dialog -->
<MudDialog @bind-Visible="dialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">@(isEdit ? "Update Student" : "Register Student")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="editStudent.FullName" Label="Full Name" Required="true" Variant="Variant.Outlined" Class="mb-4" />
        <MudTextField @bind-Value="editStudent.RollNumber" Label="Roll Number" Variant="Variant.Outlined" Class="mb-4" />
        <MudTextField @bind-Value="editStudent.Email" Label="Email Address" Required="true" Variant="Variant.Outlined" Class="mb-4" />
        <MudSelect T="Guid?" Label="Batch" @bind-Value="editStudent.BatchId" Required="true" Variant="Variant.Outlined" Class="mb-4">
            @foreach (var b in batches)
            {
                <MudSelectItem Value="@((Guid?)Guid.Parse(b.Id))">@b.Name</MudSelectItem>
            }
        </MudSelect>
        <MudNumericField @bind-Value="editStudent.EnrollmentYear" Label="Enrollment Year" Variant="Variant.Outlined" Min="2010" Max="2030" Class="mb-4" />
        <MudTextField T="string" Label="GDrive Project Link" @bind-Value="tempGDriveLink" Variant="Variant.Outlined" Placeholder="https://drive.google.com/..." Class="mb-4" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogVisible = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveStudent" Class="rounded-pill">@(isEdit ? "Update" : "Register")</MudButton>
    </DialogActions>
</MudDialog>

<!-- Progress Drawer -->
<MudDrawer @bind-Open="progressDrawerVisible" Anchor="Anchor.Right" Width="400px" Elevation="1" Variant="DrawerVariant.Temporary">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6" Class="fw-bold">Lifecycle <span class="text-secondary">Progress</span></MudText>
    </MudDrawerHeader>
    <div class="pa-4">
        @if (selectedStudent != null)
        {
            <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">@selectedStudent.FullName</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">@selectedStudent.RollNumber</MudText>

            @if (studentProgress == null)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            }
            else
            {
                <MudTimeline TimelinePosition="TimelinePosition.Start">
                    @foreach (var stage in studentProgress)
                    {
                        <MudTimelineItem Color="@GetProgressColor(stage.Status)" Size="Size.Small">
                            <ItemContent>
                                <MudText Typo="Typo.body2" Class="fw-bold">@GetStageName(stage.StageId)</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Status: @stage.Status</MudText>
                                @if (stage.MidtermScore.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Class="d-block">Midterm: @stage.MidtermScore / 100</MudText>
                                }
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            }
        }
    </div>
</MudDrawer>

@code {
    bool isLoading = true;
    bool dialogVisible = false;
    bool isEdit = false;
    bool progressDrawerVisible = false;
    string searchString = "";
    Guid? filterBatch;
    string? filterStatus;

    List<StudentEntity> students = new();
    List<BatchEntity> batches = new();
    List<NtccStage> stages = new();
    List<AcademicStageRuleEntity> allStageRules = new();
    StudentEntity editStudent = new();
    StudentEntity? selectedStudent;
    List<StudentStageProgress>? studentProgress;
    string tempGDriveLink = "";
    Dictionary<string, string> projectLinks = new(); // studentId -> gdriveLink

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        isLoading = true;
        try
        {
            batches = await Supabase.GetAll<BatchEntity>();
            stages = await StageService.GetAllStages();
            allStageRules = await Supabase.GetAll<AcademicStageRuleEntity>();
            
            if (filterBatch == null)
                students = await Supabase.GetAll<StudentEntity>();
            else
                students = await StudentService.GetStudentsByBatch(filterBatch.Value);

            // Fetch Project Links (Simplified for now: find first project per student)
            var allProjects = await Supabase.GetAll<ProjectGroupEntity>();
            var allMembers = await Supabase.GetAll<GroupMemberEntity>();
            
            projectLinks = allMembers
                .Join(allProjects, m => m.GroupId, p => p.Id, (m, p) => new { m.StudentId, p.GDriveLink })
                .Where(x => !string.IsNullOrEmpty(x.GDriveLink))
                .GroupBy(x => x.StudentId)
                .ToDictionary(g => g.Key, g => g.First().GDriveLink!);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    async Task BatchFilterChanged(Guid? val)
    {
        filterBatch = val;
        await LoadData();
    }

    AcademicStageRuleEntity? GetActiveRule(string programId, int semester) => 
        allStageRules.FirstOrDefault(r => r.ProgramId == programId && r.SemesterNumber == semester);

    string GetGDriveLink(string studentId) => projectLinks.GetValueOrDefault(studentId, "");

    IEnumerable<StudentEntity> filteredStudents => students
        .Where(s => string.IsNullOrEmpty(filterStatus) || s.Status == filterStatus);

    bool SearchFilter(StudentEntity s) => 
        string.IsNullOrWhiteSpace(searchString) || 
        s.FullName.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
        (s.RollNumber?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (s.UniversityId?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (s.EnrollmentNumber?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false);

    string GetBatchName(Guid? batchId) => batches.FirstOrDefault(b => b.Id == batchId?.ToString())?.Name ?? "Unassigned";

    Color GetStatusColor(string status) => status switch
    {
        "active" => Color.Success,
        "detained" => Color.Warning,
        "dropped" => Color.Error,
        _ => Color.Default
    };

    Color GetProgressColor(string status) => status switch
    {
        "completed" => Color.Success,
        "enrolled" => Color.Info,
        _ => Color.Default
    };

    string GetStageName(string stageId) => stages.FirstOrDefault(s => s.Id == stageId)?.Name ?? "NTCC Stage";

    void OpenAddDialog()
    {
        isEdit = false;
        editStudent = new StudentEntity { CurrentSemester = 1, Status = "active", EnrollmentYear = DateTime.Now.Year };
        dialogVisible = true;
    }

    void EditStudent(StudentEntity s)
    {
        isEdit = true;
        editStudent = s; // In real app, deep clone
        dialogVisible = true;
    }

    async Task ViewProgress(StudentEntity s)
    {
        selectedStudent = s;
        studentProgress = null;
        progressDrawerVisible = true;
        studentProgress = await StudentService.GetStudentProgress(s.Id);
    }

    async Task ViewLogs(StudentEntity s)
    {
        // Future implementation of Activity Logs
        Snackbar.Add("Opening history logs...", Severity.Info);
    }

    async Task SaveStudent()
    {
        if (string.IsNullOrWhiteSpace(editStudent.FullName) || string.IsNullOrWhiteSpace(editStudent.Email))
        {
            Snackbar.Add("Name and Email are required", Severity.Warning);
            return;
        }

        try
        {
            if (isEdit)
            {
                await Supabase.Update(editStudent);
                Snackbar.Add("Student updated successfully", Severity.Success);
            }
            else
            {
                await Supabase.Insert(editStudent);
                Snackbar.Add("Student registered successfully", Severity.Success);
            }
            
            dialogVisible = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving student: {ex.Message}", Severity.Error);
        }
    }
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.7) !important;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
        border-radius: 16px !important;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07) !important;
    }
    .fw-bold { font-weight: 800; }
    .mud-table-transparent { background: transparent !important; }
    .rounded-pill { border-radius: 50px !important; }
</style>
