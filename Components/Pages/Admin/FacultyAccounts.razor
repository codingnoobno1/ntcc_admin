@page "/admin/faculty"
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@attribute [Authorize(Roles = "admin,master")]
@inject IFacultyAppService FacultyService
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Faculty Accounts - NTCC Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <div class="d-flex justify-space-between align-center mb-8">
        <div>
            <MudText Typo="Typo.h3" Class="fw-black text-primary">Faculty Accounts</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Manage faculty access, roles, and profiles</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" Class="rounded-lg px-6 py-2 fw-bold shadow-sm" OnClick="OpenAddDialog">
            Add Faculty
        </MudButton>
    </div>

    <MudPaper Elevation="2" Class="pa-4 rounded-xl">
        <MudTable Items="@faculties" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@isLoading" LoadingProgressColor="Color.Primary" Filter="new Func<FacultyItem,bool>(FilterFunc1)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Active Personnels</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="searchString1" Placeholder="Search by name, email, or role..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<FacultyItem, object>(x=>x.Name)">Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<FacultyItem, object>(x=>x.Email)">Email</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<FacultyItem, object>(x=>x.Role)">Primary Role</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<FacultyItem, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:right">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="mr-3">@context.Name.Substring(0,1).ToUpper()</MudAvatar>
                        <MudText Typo="Typo.body2" Class="fw-bold">@context.Name</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Primary Role">
                    <MudChip T="string" Color="@GetRoleColor(context.Role)" Size="Size.Small" Variant="Variant.Text">@context.Role.ToUpper()</MudChip>
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@(context.Status == "Active" ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Filled">@context.Status</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align:right">
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Variant="Variant.Text">
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit">Edit Profile</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.VpnKey">Reset Password</MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Block" IconColor="Color.Error"><MudText Color="Color.Error">Deactivate</MudText></MudMenuItem>
                    </MudMenu>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private bool isLoading = true;
    private string searchString1 = "";

    class FacultyItem
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public string Status { get; set; } = "Active";
    }

    private List<FacultyItem> faculties = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var result = await FacultyService.GetAllFaculty();
            faculties = result.Select(f => new FacultyItem
            {
                Id = f.Id,
                Name = f.FullName,
                Email = f.Email,
                Role = f.Role,
                Status = f.IsVerified ? "Active" : "Pending"
            }).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading faculty: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool FilterFunc1(FacultyItem element) => FilterFunc(element, searchString1);

    private bool FilterFunc(FacultyItem element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Email.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if ($"{element.Role}".Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private Color GetRoleColor(string role) => role.ToLower() switch
    {
        "dean" => Color.Warning,
        "evaluator" => Color.Secondary,
        "placement" => Color.Tertiary,
        "admin" => Color.Error,
        _ => Color.Primary
    };

    [Inject] private IDialogService DialogService { get; set; } = null!;

    private async Task OpenAddDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ntcc_admin_blazor.Components.Pages.Admin.Dialogs.FacultyRegistrationDialog>("", options);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled)
        {
            // Note: In a real app we'd use a strongly typed model, 
            // but for now we access the data returned by the dialog.
            var model = result.Data as dynamic;
            var success = await FacultyService.CreateFaculty(
                (string)model.Email, 
                (string)model.FullName, 
                (string)model.Department, 
                new List<string> { (string)model.Role });

            if (success)
            {
                Snackbar.Add("Faculty account created and invitation sent!", Severity.Success);
                await LoadData();
            }
            else
            {
                Snackbar.Add("Failed to create faculty account", Severity.Error);
            }
        }
    }
}

<style>
    .fw-black { font-weight: 900; }
    .fw-bold { font-weight: 700; }
    .text-primary { color: #1976D2; }
    .shadow-sm { box-shadow: 0 4px 12px rgba(25, 118, 210, 0.2); }
</style>
