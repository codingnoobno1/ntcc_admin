            Host = "Prof. R. Sharma",
            IsActive = true,
            SubmissionCount = 120,
            TotalStudents = 120
        },
        new AcademicStage { 
            Name = "Minor Project", 
            Semester = "Sem 6", 
            Description = "Development of a software or hardware module under faculty guidance.",
            Host = "Dr. S. Singh",
            IsActive = false,
            SubmissionCount = 0,
            TotalStudents = 120
        },
        new AcademicStage { 
            Name = "45-Day Internship Evaluation", 
            Semester = "Pre-Sem 7 (Post 3rd Year)", 
            Description = "Advanced internship focusing on specialized technology stacks.",
            Host = "Prof. A. Mehta",
            IsActive = false,
            SubmissionCount = 0,
            TotalStudents = 120
        },
        new AcademicStage { 
            Name = "Major Project", 
            Semester = "Sem 7", 
            Description = "Comprehensive system design, documentation, and implementation.",
            Host = "Prof. R. Sharma",
            IsActive = false,
            SubmissionCount = 0,
            TotalStudents = 120
        },
        new AcademicStage { 
            Name = "Final Internship with PPO", 
            Semester = "Sem 8", 
            Description = "Corporate placement evaluation and Pre-Placement Offer verification.",
            Host = "Training & Placement Cell",
            IsActive = false,
            SubmissionCount = 0,
